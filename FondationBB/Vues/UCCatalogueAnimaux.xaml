<UserControl x:Class="FondationBB.UCCatalogueAnimaux"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FondationBB"
             mc:Ignorable="d" d:DesignHeight="744" d:DesignWidth="1040"
             FontFamily="{StaticResource PoliceApp}">
    <Grid Background="White" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barre d'actions : bouton "nouvel animal" réservé au responsable -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Animaux du refuge" Style="{StaticResource Titre}" VerticalAlignment="Center"/>
            <Button x:Name="butNouvel" Content="+ Nouvel animal" Style="{StaticResource BoutonPrimaire}"
                    HorizontalAlignment="Right" Click="butNouvel_Click"/>
        </Grid>

        <!-- Filtres de recherche -->
        <Border Grid.Row="1" Style="{StaticResource Carte}" Padding="14" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Recherche (nom)" Style="{StaticResource LabelChamp}"/>
                    <TextBox x:Name="txtRecherche" Style="{StaticResource Champ}"
                             TextChanged="txtRecherche_TextChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Espèce" Style="{StaticResource LabelChamp}"/>
                    <ComboBox x:Name="cbEspece" Style="{StaticResource ChampCombo}"
                              DisplayMemberPath="LibelleEspece" SelectedValuePath="IdEspece"
                              SelectionChanged="cbEspece_SelectionChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Race" Style="{StaticResource LabelChamp}"/>
                    <ComboBox x:Name="cbRace" Style="{StaticResource ChampCombo}"
                              DisplayMemberPath="LibelleRace" SelectedValuePath="IdRace"
                              SelectionChanged="cbFiltre_SelectionChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Text="Statut" Style="{StaticResource LabelChamp}"/>
                    <ComboBox x:Name="cbStatut" Style="{StaticResource ChampCombo}"
                              DisplayMemberPath="LibelleStatut" SelectedValuePath="IdStatut"
                              SelectionChanged="cbFiltre_SelectionChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Margin="0,0,10,0">
                    <TextBlock Text="Tranche d'âge" Style="{StaticResource LabelChamp}"/>
                    <ComboBox x:Name="cbTranche" Style="{StaticResource ChampCombo}"
                              SelectionChanged="cbFiltre_SelectionChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Résultats : DataGrid simple -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Tranches d'âge : Junior = moins de 2 ans · Adulte = 2 à 7 ans · Senior = plus de 7 ans"
                       Style="{StaticResource Secondaire}" Margin="2,0,0,6"/>
            <TextBlock Grid.Row="1" x:Name="txtResultats" Style="{StaticResource Secondaire}" Margin="2,0,0,10"/>

            <DataGrid Grid.Row="2" x:Name="grilleAnimaux" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                    <DataGridTextColumn Header="Espèce" Binding="{Binding Espece}" Width="100"/>
                    <DataGridTextColumn Header="Race" Binding="{Binding Race}" Width="160"/>
                    <DataGridTextColumn Header="Sexe" Binding="{Binding Sexe}" Width="80"/>
                    <DataGridTextColumn Header="Âge" Binding="{Binding Age}" Width="100"/>
                    <DataGridTextColumn Header="Statut" Binding="{Binding Statut}" Width="110"/>
                    <DataGridTemplateColumn Header="" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Voir" Click="Voir_Click" Cursor="Hand"
                                        Margin="2" Padding="10,2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
