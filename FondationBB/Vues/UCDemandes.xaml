<UserControl x:Class="FondationBB.UCDemandes"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FondationBB"
             mc:Ignorable="d" d:DesignHeight="744" d:DesignWidth="1040"
             FontFamily="{StaticResource PoliceApp}">
    <Grid Background="White" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Nouvelle demande d'adoption" Style="{StaticResource Titre}"/>
            <TextBlock Text="Enregistre les souhaits d'une famille en attente d'un animal idéal."
                       Style="{StaticResource Secondaire}" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Coordonnées du demandeur -->
                <TextBlock Text="Coordonnées" Style="{StaticResource LabelChamp}" Margin="2,0,0,6"/>
                <Border Style="{StaticResource Carte}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nom *" />
                            <TextBox x:Name="txtNom" Margin="0,0,0,12" Height="23"/>
                            <TextBlock Text="Téléphone" />
                            <TextBox x:Name="txtTelephone" Height="23"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Prénom *" />
                            <TextBox x:Name="txtPrenom" Margin="0,0,0,12" Height="23"/>
                            <TextBlock Text="Email" />
                            <TextBox x:Name="txtMail" Height="23"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Préférences sur l'animal souhaité -->
                <TextBlock Text="Animal souhaité" Margin="2,0,0,6"/>
                <Border Style="{StaticResource Carte}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Espèce" Style="{StaticResource LabelChamp}"/>
                            <ComboBox x:Name="cbEspece" Style="{StaticResource ChampCombo}"
                                      DisplayMemberPath="LibelleEspece" SelectedValuePath="IdEspece"
                                      SelectionChanged="cbEspece_SelectionChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Race (facultatif)" Style="{StaticResource LabelChamp}"/>
                            <ComboBox x:Name="cbRace" Style="{StaticResource ChampCombo}"
                                      DisplayMemberPath="LibelleRace" SelectedValuePath="IdRace"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Tranche d'âge *" Style="{StaticResource LabelChamp}"/>
                            <ComboBox x:Name="cbTranche" Style="{StaticResource ChampCombo}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <TextBlock x:Name="txtMessage" Foreground="#B3261E" FontSize="12" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Réinitialiser" Style="{StaticResource BoutonSecondaire}" Margin="0,0,10,0"
                        Click="butReset_Click"/>
                <Button Content="Enregistrer la demande" Style="{StaticResource BoutonPrimaire}"
                        Click="butValider_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
