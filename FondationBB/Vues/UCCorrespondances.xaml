<UserControl x:Class="FondationBB.UCCorrespondances"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FondationBB"
             mc:Ignorable="d" d:DesignHeight="744" d:DesignWidth="1040"
             FontFamily="{StaticResource PoliceApp}">
    <Grid Background="White" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Correspondances demandes / animaux" Style="{StaticResource Titre}"/>
            <TextBlock Text="Sélectionnez une demande pour voir les animaux disponibles qui y correspondent."
                       Style="{StaticResource Secondaire}" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Demandes en attente -->
            <Border Grid.Column="0" Style="{StaticResource Carte}" Padding="0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Demandes en attente" FontWeight="Medium"
                               Margin="14,12,14,8"/>
                    <ListBox x:Name="lbDemandes" BorderThickness="0" SelectionChanged="lbDemandes_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="6,8">
                                    <TextBlock Text="{Binding Titre}" FontWeight="Medium"/>
                                    <TextBlock Text="{Binding SousTitre}" Style="{StaticResource Secondaire}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Animaux compatibles -->
            <Border Grid.Column="2" Style="{StaticResource Carte}" Padding="0">
                <DockPanel>
                    <TextBlock x:Name="txtTitreAnimaux" DockPanel.Dock="Top" Text="Animaux compatibles"
                               FontWeight="Medium" Margin="14,12,14,8"/>
                    <DataGrid x:Name="grilleAnimaux" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                            <DataGridTextColumn Header="Espèce" Binding="{Binding Espece}" Width="120"/>
                            <DataGridTextColumn Header="Race" Binding="{Binding Race}" Width="180"/>
                            <DataGridTextColumn Header="Sexe" Binding="{Binding Sexe}" Width="90"/>
                            <DataGridTextColumn Header="Âge" Binding="{Binding Age}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
