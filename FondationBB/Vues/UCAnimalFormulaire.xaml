<UserControl x:Class="FondationBB.UCAnimalFormulaire"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FondationBB"
             mc:Ignorable="d" d:DesignHeight="744" d:DesignWidth="1040"
             FontFamily="{StaticResource PoliceApp}">
    <Grid Background="White" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTitreForm" Grid.Row="0" Text="Enregistrer un nouvel animal"
                   Style="{StaticResource Titre}" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource Carte}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Colonne gauche -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nom *" />
                            <TextBox x:Name="txtNom"  Margin="0,0,0,12" Height="28"/>

                            <TextBlock Text="Espèce *" />
                            <ComboBox x:Name="cbEspece" Margin="0,0,0,12"
                                      DisplayMemberPath="LibelleEspece" SelectedValuePath="IdEspece"
                                      SelectionChanged="cbEspece_SelectionChanged" Height="28"/>

                            <TextBlock Text="Race *" />
                            <ComboBox x:Name="cbRace" Margin="0,0,0,12"
                                      DisplayMemberPath="LibelleRace" SelectedValuePath="IdRace"/>

                            <TextBlock Text="Sexe *" />
                            <ComboBox x:Name="cbSexe"  Margin="0,0,0,12"/>

                            <TextBlock Text="Date de naissance *" />
                            <DatePicker x:Name="dpNaissance" Margin="0,0,0,12" Height="34"/>

                            <TextBlock Text="Poids (kg)"/>
                            <TextBox x:Name="txtPoids"/>
                        </StackPanel>

                        <!-- Colonne droite -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Date d'arrivée" />
                            <DatePicker x:Name="dpArrivee" Margin="0,0,0,12" Height="34"/>

                            <TextBlock Text="N° I-CAD" />
                            <TextBox x:Name="txtIcad"  Margin="0,0,0,12"/>

                            <TextBlock Text="Statut initial *" />
                            <ComboBox x:Name="cbStatut"  Margin="0,0,0,12"
                                      DisplayMemberPath="LibelleStatut" SelectedValuePath="IdStatut"/>

                            <TextBlock Text="État de santé" />
                            <ComboBox x:Name="cbEtat"  Margin="0,0,0,12"
                                      DisplayMemberPath="LibelleEtat" SelectedValuePath="IdEtat"/>

                            <TextBlock Text="Annotation" Style="{StaticResource LabelChamp}"/>
                            <TextBox x:Name="txtAnnotation" Height="70" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Comportements (cases générées dynamiquement depuis la BD) -->
                <TextBlock Text="Comportements / traits de caractère" Margin="2,0,0,8"/>
                <Border>
                    <WrapPanel x:Name="wrapComportements"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <TextBlock x:Name="txtMessage" Foreground="#B3261E" FontSize="12" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annuler"  Margin="0,0,10,0"
                        Click="butAnnuler_Click"/>
                <Button x:Name="butSauvegarder" Content="Enregistrer" Click="butSauvegarder_Click" Background="#FF0058A9"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
