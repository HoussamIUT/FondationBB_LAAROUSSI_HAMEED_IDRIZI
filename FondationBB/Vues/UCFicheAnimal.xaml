<UserControl x:Class="FondationBB.UCFicheAnimal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FondationBB"
             mc:Ignorable="d" d:DesignHeight="744" d:DesignWidth="1040"
             FontFamily="{StaticResource PoliceApp}">
    <Grid Background="White" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- En-tête : nom + pastille statut + retour -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="txtNom" Text="—" Style="{StaticResource Titre}" FontSize="24"/>
                <Border x:Name="bdStatut" CornerRadius="10" Padding="10,3" Margin="14,4,0,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="txtStatut" Text="" FontSize="11"/>
                </Border>
            </StackPanel>
            <Button Content="← Retour" Style="{StaticResource BoutonSecondaire}"
                    HorizontalAlignment="Right" Click="Retour_Click"/>
        </Grid>

        <!-- Détails -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource Carte}" Margin="0,0,0,16">
                    <StackPanel x:Name="panneauInfos"/>
                </Border>

                <TextBlock Text="Comportements" Style="{StaticResource Titre}" FontSize="15" Margin="2,0,0,8"/>
                <WrapPanel x:Name="wrapComportements" Margin="0,0,0,16"/>

                <TextBlock Text="Soins reçus" Style="{StaticResource Titre}" FontSize="15" Margin="2,0,0,8"/>
                <Border Style="{StaticResource Carte}">
                    <StackPanel x:Name="panneauSoins"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="butModifier" Content="Modifier" Style="{StaticResource BoutonSecondaire}"
                    Margin="0,0,10,0" Click="butModifier_Click"/>
            <Button x:Name="butAdopter" Content="Créer un contrat d'adoption" Style="{StaticResource BoutonPrimaire}"
                    Click="butAdopter_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
