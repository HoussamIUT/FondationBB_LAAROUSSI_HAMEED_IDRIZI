<UserControl x:Class="FondationBB.UCLogin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FondationBB"
             mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1280"
             FontFamily="{StaticResource PoliceApp}">
    <Grid Background="{StaticResource BrushPanel}">
        <!-- Carte de connexion centrée -->
        <Border Style="{StaticResource Carte}" Width="380" Padding="32"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>

                <TextBlock Text="Connexion à votre espace" Style="{StaticResource Titre}"
                           HorizontalAlignment="Center" Margin="0,16,0,2"/>
                <TextBlock Text="Accès réservé aux bénévoles et responsables"
                           Style="{StaticResource Secondaire}" HorizontalAlignment="Center" Margin="0,0,0,22"/>

                <TextBlock Text="Identifiant" Style="{StaticResource LabelChamp}"/>
                <TextBox x:Name="txtLogin"  Margin="0,0,0,14" Height="34"/>

                <TextBlock Text="Mot de passe" Style="{StaticResource LabelChamp}"/>
                <!-- PasswordBox : la saisie n'est jamais exposée en clair -->
                <PasswordBox x:Name="pwdMotDePasse" Height="34" Padding="8,6"
                             VerticalContentAlignment="Center" 
                             FontSize="13"/>

                <TextBlock x:Name="txtErreur" Foreground="#B3261E" FontSize="12"
                           TextWrapping="Wrap" Margin="0,12,0,0" Visibility="Collapsed"/>

                <Button x:Name="butConnecter" Content="Se connecter" Style="{StaticResource BoutonPrimaire}"
                        Margin="0,20,0,0" Click="butConnecter_Click"/>
            </StackPanel>
        </Border>
        <Image Margin="0,163,0,0" Source="/img/image 11.png" Stretch="Fill" HorizontalAlignment="Center" VerticalAlignment="Top" Height="82" Width="78"/>
    </Grid>
</UserControl>
