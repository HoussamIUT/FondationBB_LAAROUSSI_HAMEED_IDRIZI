<UserControl x:Class="FondationBB.UCMatching"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FondationBB"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="1000">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <StackPanel Grid.Row="0" Margin="30,20,30,10">
            <TextBlock Text="Correspondances demandes / animaux" FontSize="32"
                       Foreground="#FF242758" FontWeight="SemiBold"/>
            <TextBlock Text="Sélectionnez une demande pour voir les animaux disponibles qui correspondent."
                       FontSize="14" Foreground="Gray" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Deux colonnes : demandes à gauche, animaux compatibles à droite -->
        <Grid Grid.Row="1" Margin="30,0,30,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- Colonne gauche : liste des demandes -->
            <Border Grid.Column="0" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FF242758" CornerRadius="6,6,0,0">
                        <TextBlock Text="Demandes en attente" Foreground="White"
                                   FontWeight="SemiBold" Margin="12,8" FontSize="14"/>
                    </Border>
                    <ListBox x:Name="lbDemandes" Grid.Row="1" BorderThickness="0"
                             SelectionChanged="lbDemandes_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="6,8">
                                    <TextBlock Text="{Binding NomDemandeur}" FontWeight="SemiBold" FontSize="14"/>
                                    <TextBlock Text="{Binding Criteres}" Foreground="Gray" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Colonne droite : animaux compatibles -->
            <Border Grid.Column="2" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FF242758" CornerRadius="6,6,0,0">
                        <TextBlock x:Name="txtTitreResultats" Text="Animaux compatibles"
                                   Foreground="White" FontWeight="SemiBold" Margin="12,8" FontSize="14"/>
                    </Border>
                    <DataGrid x:Name="dgAnimaux" Grid.Row="1" AutoGenerateColumns="False"
                              IsReadOnly="True" HeadersVisibility="Column" BorderThickness="0"
                              RowHeight="36" FontSize="13" GridLinesVisibility="Horizontal"
                              RowBackground="White" AlternatingRowBackground="#FFF5F6FB">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                            <DataGridTextColumn Header="Race" Binding="{Binding Race}" Width="1.5*"/>
                            <DataGridTextColumn Header="Sexe" Binding="{Binding Sexe}" Width="0.8*"/>
                            <DataGridTextColumn Header="Âge" Binding="{Binding Age}" Width="0.8*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
