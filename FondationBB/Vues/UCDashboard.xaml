<UserControl x:Class="FondationBB.UCDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FondationBB"
             mc:Ignorable="d" d:DesignHeight="744" d:DesignWidth="1040"
             FontFamily="{StaticResource PoliceApp}">
    <ScrollViewer Background="White" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- En-tête + actualisation -->
            <Grid Margin="0,0,0,16">
                <TextBlock Text="Tableau de bord" Style="{StaticResource Titre}" VerticalAlignment="Center"/>
                <Button Content="Actualiser" Style="{StaticResource BoutonSecondaire}"
                        HorizontalAlignment="Right" Click="butActualiser_Click"/>
            </Grid>

            <!-- Cartes KPI -->
            <UniformGrid Columns="5" Margin="0,0,0,20">
                <Border Style="{StaticResource Carte}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Animaux présents" Style="{StaticResource Secondaire}"/>
                        <TextBlock x:Name="kpiPresents" Text="—" FontSize="30" FontWeight="Bold"
                                   Foreground="{StaticResource BrushPrimary}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Carte}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Disponibles" Style="{StaticResource Secondaire}"/>
                        <TextBlock x:Name="kpiDispo" Text="—" FontSize="30" FontWeight="Bold"
                                   Foreground="#27500A"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Carte}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Adoptions (total)" Style="{StaticResource Secondaire}"/>
                        <TextBlock x:Name="kpiAdoptions" Text="—" FontSize="30" FontWeight="Bold"
                                   Foreground="{StaticResource BrushPrimaryDark}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Carte}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Demandes en attente" Style="{StaticResource Secondaire}"/>
                        <TextBlock x:Name="kpiDemandes" Text="—" FontSize="30" FontWeight="Bold"
                                   Foreground="#633806"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Carte}">
                    <StackPanel>
                        <TextBlock Text="Adoptés ce mois-ci" Style="{StaticResource Secondaire}"/>
                        <TextBlock x:Name="kpiAdoptesMois" Text="—" FontSize="30" FontWeight="Bold"
                                   Foreground="#27500A"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Frais d'adoption récoltés ce mois-ci -->
            <Border Background="#242758" CornerRadius="10" Padding="22" HorizontalAlignment="Left"
                    MinWidth="380">
                <StackPanel>
                    <TextBlock Text="Frais d'adoption récoltés" Foreground="White"
                               FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtMoisCourant" Text="Mois en cours" Foreground="#9AA0C7"
                               FontSize="12" Margin="0,2,0,14"/>
                    <TextBlock x:Name="txtFraisMois" Text="0 €" Foreground="#3FE08A"
                               FontSize="40" FontWeight="Bold"/>
                    <Border BorderBrush="#3A3E6B" BorderThickness="0,1,0,0" Margin="0,16,0,0" Padding="0,12,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#3FE08A" VerticalAlignment="Center"/>
                            <TextBlock Text="Calculé en temps réel sur les contrats signés"
                                       Foreground="#C5C9E6" FontSize="12" Margin="8,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
