<UserControl x:Class="FondationBB.UCDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FondationBB"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <StackPanel Grid.Row="0" Margin="30,20,30,10">
            <TextBlock Text="Tableau de bord" FontSize="32" Foreground="#FF242758" FontWeight="SemiBold"/>
            <TextBlock Text="Vue d'ensemble de l'activité du refuge."
                       FontSize="14" Foreground="Gray" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Cartes KPI -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="30,10,30,10">
            <Border Background="#FFF0F2FA" CornerRadius="8" Margin="0,0,8,0" Padding="16">
                <StackPanel>
                    <TextBlock Text="Animaux présents" Foreground="Gray" FontSize="13"/>
                    <TextBlock x:Name="kpiPresents" Text="-" Foreground="#FF242758" FontSize="30" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="#FFF0F2FA" CornerRadius="8" Margin="4,0,4,0" Padding="16">
                <StackPanel>
                    <TextBlock Text="Disponibles" Foreground="Gray" FontSize="13"/>
                    <TextBlock x:Name="kpiDispo" Text="-" Foreground="#FF242758" FontSize="30" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="#FFF0F2FA" CornerRadius="8" Margin="4,0,4,0" Padding="16">
                <StackPanel>
                    <TextBlock Text="Adoptions" Foreground="Gray" FontSize="13"/>
                    <TextBlock x:Name="kpiAdoptions" Text="-" Foreground="#FF242758" FontSize="30" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="#FFF0F2FA" CornerRadius="8" Margin="8,0,0,0" Padding="16">
                <StackPanel>
                    <TextBlock Text="Demandes en attente" Foreground="Gray" FontSize="13"/>
                    <TextBlock x:Name="kpiDemandes" Text="-" Foreground="#FF242758" FontSize="30" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Graphiques -->
        <Grid Grid.Row="2" Margin="30,10,30,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Bar chart : adoptions par mois -->
            <Border Grid.Column="0" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="Adoptions par mois (année en cours)" FontWeight="SemiBold"
                               Foreground="#FF242758" Margin="0,0,0,12"/>
                    <Grid x:Name="zoneBarres" Height="220"/>
                </StackPanel>
            </Border>

            <!-- Répartition par statut -->
            <Border Grid.Column="2" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="Répartition par statut" FontWeight="SemiBold"
                               Foreground="#FF242758" Margin="0,0,0,12"/>
                    <StackPanel x:Name="zoneStatuts"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
