<UserControl x:Class="FondationBB.UCLogin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FondationBB"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">
        <Canvas Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" Width="294" Height="260">
            <Label Content="Connexion à votre espace" Canvas.Top="11" HorizontalAlignment="Left" VerticalAlignment="Top" FontFamily="Cambria" Height="68" Width="280" FontSize="24" Foreground="#FF242758" Canvas.Left="15"/>
            <Label Content="Accès réservé aux bénévoles et aux responsables" Canvas.Left="42" Canvas.Top="44" HorizontalAlignment="Left" VerticalAlignment="Top" FontFamily="Cambria" FontSize="10" Foreground="#FF242758"/>
            <TextBox Canvas.Left="30" TextWrapping="Wrap" Text="" Canvas.Top="108" Width="219" FontFamily="Cambria" HorizontalAlignment="Center" VerticalAlignment="Top" Height="15" TextChanged="TextBox_TextChanged" FontSize="10"/>
            <TextBox Canvas.Left="30" TextWrapping="Wrap" Text="" Canvas.Top="154" Width="219" FontFamily="Cambria" FontSize="10" Height="14" TextChanged="TextBox_TextChanged" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Button Content="Se connecter" Canvas.Left="30" Canvas.Top="193" Height="22" Width="219" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="10" BorderBrush="#FFC5D9EA" Background="#FFC5D9EA"/>
            <Label Content="Entrez votre identifiant" Canvas.Left="24" Canvas.Top="87" HorizontalAlignment="Center" Height="26" VerticalAlignment="Top" Width="136" FontSize="9"/>
            <Label Content="Entrez votre mot de passe" Canvas.Left="25" Canvas.Top="135" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        </Canvas>

    </Grid>
</UserControl>
