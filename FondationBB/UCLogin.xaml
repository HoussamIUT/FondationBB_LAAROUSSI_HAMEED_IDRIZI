             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FondationBB"
             mc:Ignorable="d" Height="550" Width="1000">
    <Grid Background="White">
        <Label Content="Connexion à votre espace" Canvas.Top="11" HorizontalAlignment="Center" VerticalAlignment="Top" FontFamily="Cambria" Height="68" Width="280" FontSize="24" Foreground="#FF242758" Canvas.Left="15" Margin="0,111,0,0"/>
        <Label Content="Accès réservé aux bénévoles et aux responsables" Canvas.Left="42" Canvas.Top="44" HorizontalAlignment="Center" VerticalAlignment="Top" FontFamily="Cambria" FontSize="10" Foreground="#FF242758" Margin="0,145,0,0"/>
        <TextBox Canvas.Left="30" TextWrapping="Wrap" Text="" Canvas.Top="108" Width="218" FontFamily="Cambria" HorizontalAlignment="Left" VerticalAlignment="Top" Height="15" TextChanged="TextBox_TextChanged" FontSize="10" Margin="369,214,0,0"/>
        <TextBox Canvas.Left="30" TextWrapping="Wrap" Text="" Canvas.Top="154" Width="219" FontFamily="Cambria" FontSize="10" Height="14" TextChanged="TextBox_TextChanged" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="368,276,0,0"/>
        <Button Content="Se connecter" Canvas.Left="30" Canvas.Top="193" Height="22" Width="218" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="10" BorderBrush="#FFC5D9EA" Background="#FFC5D9EA" Margin="369,325,0,0"/>
        <Label Content="Entrez votre identifiant" Canvas.Left="24" Canvas.Top="87" HorizontalAlignment="Left" Height="26" VerticalAlignment="Top" Width="136" FontSize="9" Margin="364,188,0,0"/>
        <Label Content="Entrez votre mot de passe" Canvas.Left="25" Canvas.Top="135" FontSize="9" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="364,249,0,0"/>
