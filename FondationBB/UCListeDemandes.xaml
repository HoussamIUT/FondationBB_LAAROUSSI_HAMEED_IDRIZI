<UserControl x:Class="FondationBB.UCListeDemandes"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FondationBB"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="1000">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <StackPanel Grid.Row="0" Margin="30,20,30,0">
            <TextBlock Text="Liste d'attente des demandes" FontSize="32" Foreground="#FF242758" FontWeight="SemiBold"/>
            <TextBlock Text="Demandes d'adoption en attente, triées par ancienneté."
                       FontSize="14" Foreground="Gray" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Barre d'action -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="30,16,30,12">
            <Button x:Name="btnRafraichir" Content="Rafraîchir" Width="110" Height="34"
                    Background="#FF3C3F87" Foreground="White" BorderThickness="0"
                    Click="btnRafraichir_Click" Cursor="Hand"/>
            <TextBlock x:Name="txtCompteur" Text="" VerticalAlignment="Center"
                       Margin="16,0,0,0" Foreground="#FF242758" FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Tableau des demandes -->
        <DataGrid x:Name="dgDemandes" Grid.Row="2" Margin="30,0,30,20"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  RowHeight="38" FontSize="13"
                  Background="White" RowBackground="White" AlternatingRowBackground="#FFF5F6FB"
                  BorderBrush="#FFE0E0E0" SelectionMode="Single">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FF242758"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Demandeur" Binding="{Binding NomDemandeur}" Width="2*"/>
                <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="1.2*"/>
                <DataGridTextColumn Header="Espèce / Race" Binding="{Binding RaceSouhaitee}" Width="1.5*"/>
                <DataGridTextColumn Header="Tranche d'âge" Binding="{Binding TrancheAge}" Width="1.2*"/>
                <DataGridTextColumn Header="Déposée le" Binding="{Binding DateDemande}" Width="1*"/>
                <DataGridTextColumn Header="Animaux compatibles" Binding="{Binding NbCorrespondances}" Width="1.3*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
